# Coppa Daemon Configuration
# Copy to coppad.toml and edit as needed.

[audio]
# Sample rate in Hz. Must match engine (48000 for OFDM).
sample_rate = 48000
# Ring buffer size in samples.
buffer_size = 8192
# Audio input device name (substring match, case-insensitive).
# Empty string = system default.
input_device = ""
# Audio output device name (substring match, case-insensitive).
# Empty string = system default.
output_device = ""

[radio]
# PTT method: "none", "vox", "serial", or "rigctld"
ptt_method = "none"
# rigctld TCP address (hamlib)
rigctld_address = "127.0.0.1:4532"
# Serial port for serial PTT (e.g. "/dev/ttyUSB0")
serial_port = ""
# Serial line for PTT: "dtr" or "rts"
serial_line = "dtr"
# Delay in ms after keying PTT before sending audio
ptt_pre_delay_ms = 50
# Delay in ms after audio ends before unkeying PTT
ptt_tail_delay_ms = 200
# Safety: max TX duration in seconds before forced unkey
max_tx_duration_s = 30

[host]
# Address all host servers (VARA-style TCP, WebSocket) bind to.
# Default "127.0.0.1" restricts access to this machine only.
# WARNING: setting this to "0.0.0.0" (or any non-loopback address) exposes an
# UNAUTHENTICATED control plane to the network. Anyone who can reach this host
# could key your transmitter. Only change this on a trusted, firewalled network.
bind_address = "127.0.0.1"
# VARA-style TCP control interface (not RF/waveform-compatible with VARA)
vara_enabled = false
vara_command_port = 8300
vara_data_port = 8301
# WebSocket JSON API
websocket_enabled = false
websocket_port = 8400

[engine]
# Profile: HF_ROBUST, HF_STANDARD, VHF_FAST, EMERGENCY
profile = "HF_STANDARD"
# Station callsign (required for connected sessions, and for the station-ID
# timer / beacon mode below -- both stay off while this is empty).
callsign = ""
# Optional Maidenhead grid locator (e.g. "FN20"), included in station-ID/
# beacon frames alongside the callsign. Free text, not validated.
# grid = ""
# Enable ARQ for reliable delivery
arq_enabled = false

[station_id]
# Busy-channel courtesy gate: once a TX request finds the channel busy (via
# the spectral-occupancy busy detector), the poll interval in ms used while
# waiting for it to clear, followed by a randomized 0.5-2s courtesy holdoff
# once it does. 0 (default) disables the gate entirely -- TX proceeds
# immediately regardless of busy state. Never adds delay when the channel is
# already clear at request time.
busy_hold_ms = 0
# Station-ID timer: minimum interval in seconds between automatic
# identification. Defaults to 540 (9 minutes) for margin under FCC Part
# 97.119's 10-minute requirement. An ID is only ever prepended to a real
# outgoing transmission (never sent standalone), and only while [engine]
# callsign above is set.
id_interval_secs = 540
# Beacon mode: interval in seconds between standalone beacon transmissions,
# sent only when the channel reads clear (skipped, not deferred, if busy --
# retried on the next tick). 0 (default) disables beacon mode. Also requires
# [engine] callsign to be set.
beacon_interval_secs = 0

# --- Session Configuration (for connected mode) ---
# These are operational defaults; session parameters are
# negotiated with the peer during connection setup.

# [session]
# ARQ window size (1-32, default 8)
# arq_window = 8
# Max retransmit attempts per frame (default 5)
# max_retries = 5
# Turnaround delay in ms between RX/TX switching (default 500)
# turnaround_ms = 500
# Connection timeout in seconds (default 30)
# connect_timeout_s = 30
# Idle timeout in seconds before session drops (default 120)
# idle_timeout_s = 120
# Max frames per TX turn before yielding (default 4)
# max_frames_per_turn = 4
